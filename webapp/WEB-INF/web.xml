<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         id="WebApp_ID" version="6.0">
  <display-name>SP_Lite</display-name>
  
   <servlet>
    <description>
		</description>
    <display-name>ConfigServlet</display-name>
    <servlet-name>ConfigServlet</servlet-name>
    <servlet-class>comapp.ConfigServlet</servlet-class>
    <init-param>
      <description>
			</description>
      <param-name>config-properties-location</param-name>
      <param-value>C:/Comapp/Config</param-value>
    </init-param>
    <load-on-startup>100</load-on-startup>
    <enabled>true</enabled>
    <async-supported>false</async-supported>
  </servlet>

  <!-- JNDI DataSource reference for connection pooling -->
  <resource-ref>
    <description>PostgreSQL DataSource for SP_Lite</description>
    <res-ref-name>jdbc/SP_Lite</res-ref-name>
    <res-type>javax.sql.DataSource</res-type>
    <res-auth>Container</res-auth>
  </resource-ref>

  <session-config>
    <session-timeout>30</session-timeout>
  </session-config>

  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
  </welcome-file-list>

  <jsp-config>
    <taglib>
      <taglib-uri>jakarta.tags.core</taglib-uri>
      <taglib-location>/WEB-INF/c.tld</taglib-location>
    </taglib>
  </jsp-config>
</web-app>